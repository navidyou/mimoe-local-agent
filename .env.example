# Copy to .env and adjust to match your mimOE node.
# Confirm the exact base URL via Model View -> API button in mimOE Studio.

# AI Foundation (mILM) default:
MIMOE_BASE_URL=http://localhost:8083/mimik-ai/openai/v1
# ai-router alternative (uncomment if the API button shows this path instead):
# MIMOE_BASE_URL=http://localhost:8083/mimik-airouter/openai/v1

MIMOE_API_KEY=1234
MIMOE_MODEL=smollm-360m

# Optional tuning
MIMOE_TEMPERATURE=0.1
MIMOE_MAX_TOKENS=512
MIMOE_MAX_STEPS=4
MIMOE_DECISION_MAX_TOKENS=1024
# Disable reasoning-model chain-of-thought for the routing step (Qwen3 etc.)
MIMOE_NO_THINK=true
MIMOE_TIMEOUT=60

# Logging level: INFO (default) or DEBUG (shows LLM traces and per-step timing,
# equivalent to running with --trace flag)
LOG_LEVEL=INFO
